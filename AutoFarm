local function saveConfig()
    if not writefile then return end
    pcall(function()
        writefile(FILE_NAME, HttpService:JSONEncode({
            FARMING_ACTIVE = FARMING_ACTIVE,
            CHEST_ACTIVE = CHEST_ACTIVE,
            currentOffset = {currentOffset.X, currentOffset.Y, currentOffset.Z},
            targets = targets
        }))
    end)
end

local function loadConfig()
    pcall(function()
        if readfile and isfile and isfile(FILE_NAME) then
            local data = HttpService:JSONDecode(readfile(FILE_NAME))
            if data then
                FARMING_ACTIVE = data.FARMING_ACTIVE
                CHEST_ACTIVE = data.CHEST_ACTIVE
                currentOffset = Vector3.new(data.currentOffset[1], data.currentOffset[2], data.currentOffset[3])
                
                -- BUG FIX #1: Ensure data-dictionary entries map back directly as clean uppercase strings [INDEX]
                if data.targets then
                    if data.targets.Mobs then
                        for k, v in pairs(data.targets.Mobs) do if targets.Mobs[k] then targets.Mobs[k] = tostring(v) end end
                    end
                    if data.targets.Bosses then
                        for k, v in pairs(data.targets.Bosses) do if targets.Bosses[k] then targets.Bosses[k] = tostring(v) end end
                    end
                end
            end
        end
    end)
end
