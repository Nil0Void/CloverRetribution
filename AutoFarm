-- Slider Construction Module with Expanded Ranges
local function createSlider(axisName, minVal, maxVal, startVal, yOffset)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 0, 20)
    label.Position = UDim2.new(0, 10, 0, yOffset)
    label.BackgroundTransparency = 1
    local suffix = (axisName:find("Orbit") and "°") or " studs"
    label.Text = axisName .. ": " .. tostring(startVal) .. suffix
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 8)
    sliderBg.Position = UDim2.new(0, 10, 0, yOffset + 20)
    sliderBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = frame

    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(0, 16, 0, 16)
    local pct = (startVal - minVal) / (maxVal - minVal)
    sliderBtn.Position = UDim2.new(pct, -8, 0.5, -8)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
    sliderBtn.Text = ""
    sliderBtn.BorderSizePixel = 0
    sliderBtn.Parent = sliderBg

    local activeDragging = false

    local function updateSliderPosition(inputPosition)
        local barAbsPos = sliderBg.AbsolutePosition.X
        local barAbsSize = sliderBg.AbsoluteSize.X
        local clmp = math.clamp((inputPosition.X - barAbsPos) / barAbsSize, 0, 1)
        
        sliderBtn.Position = UDim2.new(clmp, -8, 0.5, -8)
        local value = math.round(minVal + (clmp * (maxVal - minVal)))
        label.Text = axisName .. ": " .. tostring(value) .. suffix
        
        if axisName == "🔄 Orbit Position" then
            currentOffset = Vector3.new(value, currentOffset.Y, currentOffset.Z)
        elseif axisName == "📐 Height" then
            currentOffset = Vector3.new(currentOffset.X, value, currentOffset.Z)
        elseif axisName == "📏 Distance" then
            currentOffset = Vector3.new(currentOffset.X, currentOffset.Y, value)
        end
    end

    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeDragging = true
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if activeDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSliderPosition(input.Position)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeDragging = false
        end
    end)
end

