-- Category Frame Generation Helper
local function createCategoryScroll(titleText, xOffset, targetSubTable)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, 205, 0, 220)
    container.Position = UDim2.new(0, xOffset, 0, 90)
    container.BackgroundTransparency = 1
    container.Parent = frame

    local catTitle = Instance.new("TextLabel")
    catTitle.Size = UDim2.new(1, 0, 0, 20)
    catTitle.BackgroundTransparency = 1
    catTitle.Text = titleText
    catTitle.TextColor3 = Color3.fromRGB(200, 200, 200)
    catTitle.Font = Enum.Font.SourceSansBold
    catTitle.TextSize = 14
    catTitle.Parent = container

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, -25)
    scroll.Position = UDim2.new(0, 0, 0, 25)
    scroll.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0) -- Managed by code
    scroll.ScrollBarThickness = 5
    scroll.Parent = container

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Parent = scroll

    -- Populate items dynamically alphabetical order sorted
    local sortedNames = {}
    for name in pairs(targetSubTable) do table.insert(sortedNames, name) end
    table.sort(sortedNames)

    for _, mobName in ipairs(sortedNames) do
        local mobBtn = Instance.new("TextButton")
        mobBtn.Size = UDim2.new(0, 190, 0, 30)
        mobBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        mobBtn.Text = mobName .. " [OFF]"
        mobBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        mobBtn.Font = Enum.Font.SourceSans
        mobBtn.TextSize = 13
        mobBtn.Parent = scroll

        mobBtn.MouseButton1Click:Connect(function()
            targetSubTable[mobName] = not targetSubTable[mobName]
            if targetSubTable[mobName] then
                mobBtn.Text = mobName .. " [ON]"
                mobBtn.BackgroundColor3 = Color3.fromRGB(56, 92, 145)
                mobBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            else
                mobBtn.Text = mobName .. " [OFF]"
                mobBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                mobBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        end)
    end
    
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end

