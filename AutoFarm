-- UI Dragging Framework
local dragging, dragStart, startPos = false, nil, nil
frame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and input.Position.Y - frame.AbsolutePosition.Y <= 35 then
        dragging, dragStart, startPos = true, input.Position, frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

-- Target Detection Helper (Partial Match)
local function getActiveFarmTarget()
    local enemiesFolder = workspace:FindFirstChild("Entities")
    enemiesFolder = enemiesFolder and enemiesFolder:FindFirstChild("Enemies")
    if not enemiesFolder then return nil end

    for _, mob in ipairs(enemiesFolder:GetChildren()) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            
            for enabledBossName, isEnabled in pairs(targets.Bosses) do
                if isEnabled and string.find(lowerMobName, string.lower(enabledBossName), 1, true) then return mob end
            end
            
            for enabledMobName, isEnabled in pairs(targets.Mobs) do
                if isEnabled and string.find(lowerMobName, string.lower(enabledMobName), 1, true) then return mob end
            end
        end
    end
    return nil
end

-- Fly & Vertical Orbit Core Loop Mathematics
RunService.RenderStepped:Connect(function()
    local character = player.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    local myHum = character and character:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or (myHum and myHum.Health <= 0) then 
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
        return 
    end

    if not FARMING_ACTIVE then 
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
        return 
    end

    local currentEnemy = getActiveFarmTarget()
    if currentEnemy and currentEnemy:FindFirstChild("HumanoidRootPart") then
        local enemyRoot = currentEnemy.HumanoidRootPart
        
        -- Create a bulletproof physics anchor to stop all screen shaking and drifting
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.Name = "AntiDriftAnchor"
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end
        
        -- VERTICAL ORBITAL MATHEMATICS:
        -- Convert the X slider value into a vertical angle calculation (radians)
        local angleRad = math.rad(currentOffset.X) 
        local radiusDistance = currentOffset.Z
        local staticHeightAdjust = currentOffset.Y
        
        -- Calculate the vertical orbit along the Y (up/down) and Z (front/back) axes
        -- This forces the rotation to loop over the top/underneath instead of horizontally
        local orbitY = math.sin(angleRad) * radiusDistance + staticHeightAdjust
        local orbitZ = math.cos(angleRad) * radiusDistance
        local orbitX = 0 -- Keeps you aligned perfectly straight on the center line
        
        -- Calculate the world position offset relative to the enemy's facing direction
        local worldOffsetPosition = (enemyRoot.CFrame * CFrame.new(orbitX, orbitY, orbitZ)).Position
        
        -- Keep your character positioned perfectly on the vertical orbital track while face-locked
        myRoot.CFrame = CFrame.lookAt(worldOffsetPosition, enemyRoot.Position)
    else
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
    end
end)

