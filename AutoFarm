local function getActiveEventChestPrompt()
    if not CHECH_ACTIVE or not CHEST_ACTIVE then return nil end

    local eventsFolder = workspace:FindFirstChild("Entities")
    eventsFolder = eventsFolder and eventsFolder:FindFirstChild("Events")
    if not eventsFolder then return nil end

    for _, item in ipairs(eventsFolder:GetDescendants()) do
        if item:IsA("Model") and item.Name == "Chest" and not processedChests[item] then
            
            -- Credit Verification Layer
            local creditedFolder = item:FindFirstChild("Credited")
            if creditedFolder then
                local isMyChest = false
                for _, credit in ipairs(creditedFolder:GetChildren()) do
                    if string.find(string.lower(credit.Name), string.lower(player.Name), 1, true) then
                        isMyChest = true
                        break
                    end
                end
                if not isMyChest then continue end
            end
            
            local targetPart = item:FindFirstChild("middle") or item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart", true)
            if targetPart then
                local prompt = item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChild("ProximityPrompt", true)
                if prompt then
                    return prompt, item, targetPart
                end
            end
        end
    end
    return nil
end

-- Target Detection Helper (Partial Match + Tri-State Priority Layer Filtering)
local function getActiveFarmTarget()
    local enemiesFolder = workspace:FindFirstChild("Entities")
    enemiesFolder = enemiesFolder and enemiesFolder:FindFirstChild("Enemies")
    if not enemiesFolder then 
        currentTarget = nil
        return nil 
    end

    local enemiesList = enemiesFolder:GetChildren()

    -- LAYER 1: Starred PRIORITY targets
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            
            for name, state in pairs(targets.Bosses) do
                if state == "PRIORITY" and string.find(lowerMobName, string.lower(name), 1, true) then
                    currentTarget = mob
                    return currentTarget
                end
            end
            
            for name, state in pairs(targets.Mobs) do
                if state == "PRIORITY" and string.find(lowerMobName, string.lower(name), 1, true) then
                    currentTarget = mob
                    return currentTarget
                end
            end
        end
    end

    -- LAYER 2: Regular Bosses
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            
            for name, state in pairs(targets.Bosses) do
                if state == "ON" and string.find(lowerMobName, string.lower(name), 1, true) then
                    currentTarget = mob
                    return currentTarget
                end
            end
        end
    end

    -- LAYER 3: Sticky Check
    if currentTarget and currentTarget.Parent == enemiesFolder then
        local mobRoot = currentTarget:FindFirstChild("HumanoidRootPart")
        local mobHum = currentTarget:FindFirstChildOfClass("Humanoid")
        if mobRoot and mobHum and mobHum.Health > 0 then
            local currentLower = string.lower(currentTarget.Name)
            local isStillEnabled = false
            
            for name, state in pairs(targets.Mobs) do
                if state == "ON" and string.find(currentLower, string.lower(name), 1, true) then isStillEnabled = true break end
            end
            
            if isStillEnabled then return currentTarget end
        end
    end

    -- LAYER 4: Standard Mobs
    currentTarget = nil
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            
            for name, state in pairs(targets.Mobs) do
                if state == "ON" and string.find(lowerMobName, string.lower(name), 1, true) then
                    currentTarget = mob
                    return currentTarget
                end
            end
        end
    end

    return nil
end

-- Fly & Vertical Orbit Loop
RunService.RenderStepped:Connect(function()
    local character = player.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    local myHum = character and character:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or (myHum and myHum.Health <= 0) then 
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
        return 
    end

    if not FARMING_ACTIVE then 
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
        currentTarget = nil 
        return 
    end

    -- ABSOLUTE TOP PRIORITY: Intercept chest first and skip enemy code entirely
    local chestPrompt, chestModel, chestMiddlePart = getActiveEventChestPrompt()
    if chestPrompt and chestModel and chestMiddlePart then
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.Name = "AntiDriftAnchor"
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end

        -- Teleport instantly to the chest and exit the RenderStepped frame execution
        myRoot.CFrame = chestMiddlePart.CFrame * CFrame.new(0, 3, 0)
        return
    end

    -- Standard Combat Targeting Loop (Only runs if NO chest is active)
    local currentEnemy = getActiveFarmTarget()
    if currentEnemy and currentEnemy:FindFirstChild("HumanoidRootPart") then
        local enemyRoot = currentEnemy.HumanoidRootPart
        
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.Name = "AntiDriftAnchor"
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end
        
        local angleRad = math.rad(currentOffset.X) 
        local radiusDistance = currentOffset.Z
        local staticHeightAdjust = currentOffset.Y
        
        local orbitY = math.sin(angleRad) * radiusDistance + staticHeightAdjust
        local orbitZ = math.cos(angleRad) * radiusDistance
        local orbitX = 0 
        
        local worldOffsetPosition = (enemyRoot.CFrame * CFrame.new(orbitX, orbitY, orbitZ)).Position
        myRoot.CFrame = CFrame.lookAt(worldOffsetPosition, enemyRoot.Position)
    else
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
    end
end)

