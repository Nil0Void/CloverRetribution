-- 4. Flower Farm Loop
task.spawn(function()
    while true do
        if flags.flower then
            pcall(function()
                local folder = workspace:FindFirstChild("Entities")
                folder = folder and folder:FindFirstChild("Interactions")
                folder = folder and folder:FindFirstChild("Collectibles")
                folder = folder and folder:FindFirstChild("Flowers")
                
                if not folder then return end

                local HRP = getRoot()
                if not HRP then return end

                local flowers = {}
                for _, v in ipairs(folder:GetDescendants()) do
                    if getPrompt(v) then table.insert(flowers, v) end
                end

                table.sort(flowers, function(a, b)
                    local aLily = a.Name:lower():find("lily") ~= nil
                    local bLily = b.Name:lower():find("lily") ~= nil
                    if aLily ~= bLily then return aLily end
                    return a.Name < b.Name
                end)

                for _, flower in ipairs(flowers) do
                    if not flags.flower then break end
                    local part = getPart(flower)
                    local prompt = getPrompt(flower)

                    if part and prompt then
                        HRP.CFrame = part.CFrame + Vector3.new(0, 3, 0)
                        local startTime = tick()
                        while flags.flower and tick() - startTime < FLOWER_DELAY do
                            if prompt and prompt.Parent then fireproximityprompt(prompt) end
                            task.wait()
                        end
                    end
                end

                if flags.flower then
                    HRP.CFrame = CFrame.new(SAFEZONE)
                    local elapsed = 0
                    while flags.flower and elapsed < LOOP_DELAY do
                        task.wait(0.1)
                        elapsed = elapsed + 0.1
                    end
                end
            end)
        else
            task.wait(0.5)
        end
    end
end)

-- 5. Auto Walk & Reset Connection
local phaseStartTime = os.clock()
local characterResetTriggered = false

RunService.RenderStepped:Connect(function()
    if not flags.walk then 
        characterResetTriggered = false
        return 
    end
    
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local primaryPart = character and character.PrimaryPart
    
    if humanoid and primaryPart and humanoid.Health > 0 then
        local elapsed = os.clock() - phaseStartTime
        
        if elapsed < MOVE_DURATION then
            -- Phase 1: Keep pushing forward based on camera orientation
            local moveDirection = primaryPart.CFrame.LookVector
            humanoid:Move(moveDirection, false)
        elseif elapsed < RESET_TIME then
            -- Phase 2: Stand completely still
            humanoid:Move(Vector3.new(0, 0, 0), false)
        else
            -- Phase 3: Trigger the clean character death reset
            if not characterResetTriggered then
                characterResetTriggered = true
                humanoid.Health = 0
            end
        end
    else
        -- Instantly refresh clock tracking while dead to pick up smoothly when respawning
        phaseStartTime = os.clock()
        characterResetTriggered = false
    end
end)

