-- Helper function to fetch the next valid chest in our cycling queue
local function getActiveEventChestPrompt()
    if not CHEST_ACTIVE then return nil end

    local validChests = {}
    
    for i = #activeChestsCache, 1, -1 do
        local item = activeChestsCache[i]
        
        if not item or not item.Parent then
            chestVisitTimers[item] = nil 
            chestVisitCounts[item] = nil 
            table.remove(activeChestsCache, i)
            continue
        end

        if chestVisitCounts[item] and chestVisitCounts[item] >= 2 then
            continue
        end

        local creditedFolder = item:FindFirstChild("Credited")
        if creditedFolder then
            local isMyChest = false
            for _, credit in ipairs(creditedFolder:GetChildren()) do
                if string.find(string.lower(credit.Name), string.lower(player.Name), 1, true) then isMyChest = true break end
            end
            if not isMyChest then continue end
        end

        local prompt = item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChild("ProximityPrompt", true)
        local targetPart = prompt and (prompt.Parent:IsA("BasePart") and prompt.Parent or item:FindFirstChild("middle") or item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart", true))
        
        if prompt and targetPart then
            table.insert(validChests, {prompt = prompt, model = item, part = targetPart})
        end
    end

    if #validChests == 0 then
        currentChestIndex = nil
        return nil
    end

    if currentChestIndex and currentChestIndex <= #validChests then
        local activeSelection = validChests[currentChestIndex]
        local startTime = chestVisitTimers[activeSelection.model]
        
        if startTime and (os.clock() - startTime) < 3 then
            return activeSelection.prompt, activeSelection.model, activeSelection.part
        elseif startTime then
            chestVisitCounts[activeSelection.model] = (chestVisitCounts[activeSelection.model] or 0) + 1
            chestVisitTimers[activeSelection.model] = nil 
        end
    end

    local nextIndex = 1
    if currentChestIndex then
        nextIndex = (currentChestIndex % #validChests) + 1
    end

    local loopsChecked = 0
    while loopsChecked < #validChests do
        local checkSelection = validChests[nextIndex]
        if not chestVisitCounts[checkSelection.model] or chestVisitCounts[checkSelection.model] < 2 then
            break 
        end
        nextIndex = (nextIndex % #validChests) + 1
        loopsChecked = loopsChecked + 1
    end

    local finalSelection = validChests[nextIndex]
    
    if chestVisitCounts[finalSelection.model] and chestVisitCounts[finalSelection.model] >= 2 then
        currentChestIndex = nil
        return nil
    end

    currentChestIndex = nextIndex
    chestVisitTimers[finalSelection.model] = os.clock() 

    return finalSelection.prompt, finalSelection.model, finalSelection.part
end

-- NEW: Helper function to target Dragon Balls inside workspace.Ignore
local function getActiveDragonBall()
    if not DRAGONBALL_ACTIVE then return nil end
    local ignoreFolder = workspace:FindFirstChild("Ignore")
    if not ignoreFolder then return nil end
    
    for _, obj in ipairs(ignoreFolder:GetChildren()) do
        if string.match(obj.Name, "^Dragon Ball %d+$") then
            local part = obj:IsA("BasePart") and obj or obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart", true)
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt", true)
            if part and prompt then
                return obj, part, prompt
            end
        end
    end
    return nil
end

-- Target Detection Helper (Partial Match + Tri-State Priority Layer Filtering)
local function getActiveFarmTarget()
    local enemiesFolder = workspace:FindFirstChild("Entities")
    enemiesFolder = enemiesFolder and enemiesFolder:FindFirstChild("Enemies")
    if not enemiesFolder then currentTarget = nil return nil end
    local enemiesList = enemiesFolder:GetChildren()

    -- LAYER 1: Starred PRIORITY targets
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            for name, state in pairs(targets.Bosses) do if state == "PRIORITY" and string.find(lowerMobName, string.lower(name), 1, true) then currentTarget = mob return currentTarget end end
            for name, state in pairs(targets.Mobs) do if state == "PRIORITY" and string.find(lowerMobName, string.lower(name), 1, true) then currentTarget = mob return currentTarget end end
        end
    end

    -- LAYER 2: Regular Bosses
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            for name, state in pairs(targets.Bosses) do if state == "ON" and string.find(lowerMobName, string.lower(name), 1, true) then currentTarget = mob return currentTarget end end
        end
    end

    -- LAYER 3: Sticky Check
    if currentTarget and currentTarget.Parent == enemiesFolder then
        local mobRoot = currentTarget:FindFirstChild("HumanoidRootPart")
        local mobHum = currentTarget:FindFirstChildOfClass("Humanoid")
        if mobRoot and mobHum and mobHum.Health > 0 then
            local currentLower = string.lower(currentTarget.Name)
            local isStillEnabled = false
            for name, state in pairs(targets.Mobs) do if state == "ON" and string.find(currentLower, string.lower(name), 1, true) then isStillEnabled = true break end end
            if isStillEnabled then return currentTarget end
        end
    end

    -- LAYER 4: Standard Mobs
    currentTarget = nil
    for _, mob in ipairs(enemiesList) do
        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChildOfClass("Humanoid")
        if mobRoot and mobHum and mobHum.Health > 0 then
            local lowerMobName = string.lower(mob.Name)
            for name, state in pairs(targets.Mobs) do if state == "ON" and string.find(lowerMobName, string.lower(name), 1, true) then currentTarget = mob return currentTarget end end
        end
    end
    return nil
end

-- Fly & Vertical Orbit Loop
RunService.RenderStepped:Connect(function()
    local character = player.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    local myHum = character and character:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or (myHum and myHum.Health <= 0) then if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end return end

    -------------------------------------------------------------------------------------
    -- CRITICAL OVERRIDE: Absolute Dragon Ball Check. Stops all farming physics instantly
    -------------------------------------------------------------------------------------
    local dbModel, dbPart, dbPrompt = getActiveDragonBall()
    if dbModel and dbPart and dbPrompt then
        return -- Yield physics frame completely over to the background hyper-speed engine
    end
    -------------------------------------------------------------------------------------

    if not FARMING_ACTIVE then if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end currentTarget = nil return end

    -- CHEST QUEUE OVERRIDE LATCH
    local chestPrompt, chestModel, chestMiddlePart = getActiveEventChestPrompt()
    if chestPrompt and chestModel and chestMiddlePart then
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.Name = "AntiDriftAnchor"
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end
        myRoot.CFrame = chestMiddlePart.CFrame * CFrame.new(0, 2, 0)
        return
    end

    -- Standard Combat Targeting Loop
    local currentEnemy = getActiveFarmTarget()
    if currentEnemy and currentEnemy:FindFirstChild("HumanoidRootPart") then
        local enemyRoot = currentEnemy.HumanoidRootPart
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.Name = "AntiDriftAnchor"
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end
        local angleRad = math.rad(currentOffset.X) 
        local radiusDistance = currentOffset.Z
        local staticHeightAdjust = currentOffset.Y
        local orbitY = math.sin(angleRad) * radiusDistance + staticHeightAdjust
        local orbitZ = math.cos(angleRad) * radiusDistance
        local worldOffsetPosition = (enemyRoot.CFrame * CFrame.new(0, orbitY, orbitZ)).Position
        myRoot.CFrame = CFrame.lookAt(worldOffsetPosition, enemyRoot.Position)
    else
        if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end
    end
end)

