local FLOWER_DELAY = 1.5 -- Duration to spend harvesting each flower before moving on

local function getActiveFlowerTarget()
    if not FLOWER_ACTIVE then return nil, nil end
    
    local folder = workspace:FindFirstChild("Entities")
    folder = folder and folder:FindFirstChild("Interactions")
    folder = folder and folder:FindFirstChild("Collectibles")
    folder = folder and folder:FindFirstChild("Flowers")
    
    if not folder then return nil, nil end

    local flowers = {}
    -- Safely scan for all operational prompts inside the collectibles folder
    for _, v in ipairs(folder:GetDescendants()) do
        local prompt = v:FindFirstChildOfClass("ProximityPrompt") or v:FindFirstChild("ProximityPrompt", true)
        if prompt then 
            table.insert(flowers, v) 
        end
    end

    -- Sort Lily types first, then sort alphabetically by asset name
    table.sort(flowers, function(a, b)
        local aLily = a.Name:lower():find("lily") ~= nil
        local bLily = b.Name:lower():find("lily") ~= nil
        if aLily ~= bLily then return aLily end
        return a.Name < b.Name
    end)

    -- Extract valid visual parts and operational prompt components
    for _, flower in ipairs(flowers) do
        local part = flower:IsA("BasePart") and flower 
            or flower:FindFirstChild("Handle") 
            or flower:FindFirstChildWhichIsA("BasePart", true)
            
        local prompt = flower:FindFirstChildOfClass("ProximityPrompt") 
            or flower:FindFirstChild("ProximityPrompt", true)

        if part and prompt and prompt.Parent then
            return part, prompt
        end
    end
    
    return nil, nil
end

