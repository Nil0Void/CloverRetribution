        if activeDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local clmp = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
            local val = math.round(minVal + (clmp * (maxVal - minVal)))
            if axisName == "🔄 Orbit Position" then currentOffset = Vector3.new(val, currentOffset.Y, currentOffset.Z)
