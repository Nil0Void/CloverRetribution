-- Tracked Chest Memory & Active Object Collections
local activeChestsCache = {}
local chestVisitTimers = {}
local chestVisitCounts = {}
local currentChestIndex = nil

-- Real-time folder hook listens for chest spawns instantly (Cleaned Memory Leak)
local function monitorWorkspaceEvents()
    local entities = workspace:FindFirstChild("Entities")
    local eventsFolder = entities and entities:FindFirstChild("Events")
    if not eventsFolder then return end
    
    -- Periodic Garbage Collection of memory cache arrays to prevent RAM inflation
    task.spawn(function()
        while true do
            task.wait(30) -- Run a deep clean cycle every 30 seconds
            for i = #activeChestsCache, 1, -1 do
                local item = activeChestsCache[i]
                if not item or not item.Parent then
                    chestVisitTimers[item] = nil 
                    chestVisitCounts[item] = nil
                    table.remove(activeChestsCache, i)
                end
            end
        end
    end)

    eventsFolder.DescendantAdded:Connect(function(descendant) 
        if descendant:IsA("Model") and descendant.Name == "Chest" then 
            -- Avoid duplicate references
            if not table.find(activeChestsCache, descendant) then
                table.insert(activeChestsCache, descendant) 
            end
        end 
    end)
    
    for _, descendant in ipairs(eventsFolder:GetDescendants()) do 
        if descendant:IsA("Model") and descendant.Name == "Chest" then 
            table.insert(activeChestsCache, descendant) 
        end 
    end
end
task.spawn(monitorWorkspaceEvents)

-- Helper function to fetch the next valid chest in our cycling queue
local function getActiveEventChestPrompt()
    if not CHEST_ACTIVE then return nil end

    local validChests = {}
    
    -- Parse active live cache cleanly
    for i = #activeChestsCache, 1, -1 do
        local item = activeChestsCache[i]
        
        -- Instantly purge invalid game items from memory
        if not item or not item.Parent then
            chestVisitTimers[item] = nil 
            chestVisitCounts[item] = nil
            table.remove(activeChestsCache, i)
            continue
        end

        -- HARD CAP OVERRIDE: Skip if 2 rounds are completed
        if chestVisitCounts[item] and chestVisitCounts[item] >= 2 then
            continue
        end

        -- Credit Tracker Verification Layer
        local creditedFolder = item:FindFirstChild("Credited")
        if creditedFolder then
            local isMyChest = false
            for _, credit in ipairs(creditedFolder:GetChildren()) do
                if string.find(string.lower(credit.Name), string.lower(player.Name), 1, true) then 
                    isMyChest = true 
                    break 
                end
            end
            if not isMyChest then continue end
        end

        local prompt = item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChild("ProximityPrompt", true)
        local targetPart = prompt and (prompt.Parent:IsA("BasePart") and prompt.Parent or item:FindFirstChild("middle") or item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart", true))
        
        if prompt and targetPart then
            table.insert(validChests, {prompt = prompt, model = item, part = targetPart})
        end
    end

    if #validChests == 0 then
        currentChestIndex = nil
        return nil
    end

    -- Verify if our active selection is still within its 3-second loop window
    if currentChestIndex and currentChestIndex <= #validChests then
        local activeSelection = validChests[currentChestIndex]
        local startTime = chestVisitTimers[activeSelection.model]
        
        if startTime and (os.clock() - startTime) < 3 then
            return activeSelection.prompt, activeSelection.model, activeSelection.part
        elseif startTime then
            chestVisitCounts[activeSelection.model] = (chestVisitCounts[activeSelection.model] or 0) + 1
            chestVisitTimers[activeSelection.model] = nil 
        end
    end

    -- Cycle to the next available chest index carousel point
    local nextIndex = 1
    if currentChestIndex then
        nextIndex = (currentChestIndex % #validChests) + 1
    end

    local loopsChecked = 0
    while loopsChecked < #validChests do
        local checkSelection = validChests[nextIndex]
        if not chestVisitCounts[checkSelection.model] or chestVisitCounts[checkSelection.model] < 2 then
            break 
        end
        nextIndex = (nextIndex % #validChests) + 1
        loopsChecked = loopsChecked + 1
    end

    local finalSelection = validChests[nextIndex]
    
    if chestVisitCounts[finalSelection.model] and chestVisitCounts[finalSelection.model] >= 2 then
        currentChestIndex = nil
        return nil
    end

    currentChestIndex = nextIndex
    chestVisitTimers[finalSelection.model] = os.clock() 

    return finalSelection.prompt, finalSelection.model, finalSelection.part
end


local function getActiveDragonBall()
    if not DRAGONBALL_ACTIVE then return nil end
    local folder = workspace:FindFirstChild("Ignore")
    if not folder then return nil end
    for _, obj in ipairs(folder:GetChildren()) do
        if string.match(obj.Name, "^Dragon Ball %d+$") then
            local part = obj:IsA("BasePart") and obj or obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart", true)
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt", true)
            if part and prompt then return obj, part, prompt end
        end
    end
    return nil
end

local function getActiveFarmTarget()
    local folder = workspace:FindFirstChild("Entities")
    folder = folder and folder:FindFirstChild("Enemies")
    if not folder then currentTarget = nil return nil end
    local list = folder:GetChildren()

    -- Layer 1: Priority
    for _, m in ipairs(list) do
        if m:FindFirstChild("HumanoidRootPart") and m:FindFirstChildOfClass("Humanoid") and m:FindFirstChildOfClass("Humanoid").Health > 0 then
            local low = m.Name:lower()
            for k, v in pairs(targets.Bosses) do if v == "PRIORITY" and low:find(k:lower(), 1, true) then currentTarget = m return m end end
            for k, v in pairs(targets.Mobs) do if v == "PRIORITY" and low:find(k:lower(), 1, true) then currentTarget = m return m end end
        end
    end
    -- Layer 2: Regular Bosses
    for _, m in ipairs(list) do
        if m:FindFirstChild("HumanoidRootPart") and m:FindFirstChildOfClass("Humanoid") and m:FindFirstChildOfClass("Humanoid").Health > 0 then
            local low = m.Name:lower()
            for k, v in pairs(targets.Bosses) do if v == "ON" and low:find(k:lower(), 1, true) then currentTarget = m return m end end
        end
    end
    -- Layer 3: Sticky Mobs Check
    if currentTarget and currentTarget.Parent == folder and currentTarget:FindFirstChild("HumanoidRootPart") and currentTarget:FindFirstChildOfClass("Humanoid") and currentTarget:FindFirstChildOfClass("Humanoid").Health > 0 then
        local low = currentTarget.Name:lower()
        for k, v in pairs(targets.Mobs) do if v == "ON" and low:find(k:lower(), 1, true) then return currentTarget end end
    end
    -- Layer 4: Standard Mobs
    currentTarget = nil
    for _, m in ipairs(list) do
        if m:FindFirstChild("HumanoidRootPart") and m:FindFirstChildOfClass("Humanoid") and m:FindFirstChildOfClass("Humanoid").Health > 0 then
            local low = m.Name:lower()
            for k, v in pairs(targets.Mobs) do if v == "ON" and low:find(k:lower(), 1, true) then currentTarget = m return m end end
        end
    end
    return nil
end

-- Combined High-Priority Vector Mechanics Engine
RunService.RenderStepped:Connect(function()
    local character = player.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    local myHum = character and character:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or (myHum and myHum.Health <= 0) then if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end return end

    -- INTEGRATED WALK CYCLE LOGIC (Independent of early returns, works during farming)
    if WALK_ACTIVE and myHum and myHum.Health > 0 then
        local elapsed = os.clock() - phaseStartTime
        if elapsed < MOVE_DURATION then
            myHum:Move(myRoot.CFrame.LookVector, false)
        elseif elapsed < RESET_TIME then
            myHum:Move(Vector3.new(0, 0, 0), false)
        else
            if not characterResetTriggered then
                characterResetTriggered = true
                myHum.Health = 0
            end
        end
    else
        phaseStartTime = os.clock()
        characterResetTriggered = false
    end

    ---------------------------------------------------------------------------------
    -- POSITIONING OVERRIDE LAYER 1: Dragon Ball Engine Hard lock
    ---------------------------------------------------------------------------------
    local dbModel, dbPart, dbPrompt = getActiveDragonBall()
    if dbModel and dbPart and dbPrompt then return end

    ---------------------------------------------------------------------------------
    -- POSITIONING OVERRIDE LAYER 2: Flower TP Loop Hold
    ---------------------------------------------------------------------------------
    if FLOWER_ACTIVE then return end

    if not FARMING_ACTIVE then if flyAnchor then flyAnchor:Destroy() flyAnchor = nil end currentTarget = nil return end

    -- CHEST QUEUE OVERRIDE LATCH
    local chestPrompt, chestModel, chestMiddlePart = getActiveEventChestPrompt()
    if chestPrompt and chestModel and chestMiddlePart then
        if not flyAnchor or flyAnchor.Parent ~= myRoot then
            if flyAnchor then flyAnchor:Destroy() end
            flyAnchor = Instance.new("BodyVelocity")
            flyAnchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            flyAnchor.Velocity = Vector3.new(0, 0, 0)
            flyAnchor.Parent = myRoot
        end
        myRoot.CFrame = chestMiddlePart.CFrame * CFrame.new(0, 2, 0)
        return
    end

