local function saveConfig()
    if not writefile then return end
    pcall(function()
        writefile(FILE_NAME, HttpService:JSONEncode({
            FARMING_ACTIVE = FARMING_ACTIVE, CHEST_ACTIVE = CHEST_ACTIVE, DRAGONBALL_ACTIVE = DRAGONBALL_ACTIVE,
            FLOWER_ACTIVE = FLOWER_ACTIVE, WEAPON_ACTIVE = WEAPON_ACTIVE, SPELL_ACTIVE = SPELL_ACTIVE,
            WALK_ACTIVE = WALK_ACTIVE, SPAWN_TP_ACTIVE = SPAWN_TP_ACTIVE,
            currentOffset = {currentOffset.X, currentOffset.Y, currentOffset.Z}, targets = targets
        }))
    end)
end

local function loadConfig()
    pcall(function()
        if readfile and isfile and isfile(FILE_NAME) then
            local data = HttpService:JSONDecode(readfile(FILE_NAME))
            if data then
                FARMING_ACTIVE = data.FARMING_ACTIVE or false CHEST_ACTIVE = data.CHEST_ACTIVE or false
                DRAGONBALL_ACTIVE = data.DRAGONBALL_ACTIVE or false FLOWER_ACTIVE = data.FLOWER_ACTIVE or false
                WEAPON_ACTIVE = data.WEAPON_ACTIVE or false SPELL_ACTIVE = data.SPELL_ACTIVE or false
                WALK_ACTIVE = data.WALK_ACTIVE or false SPAWN_TP_ACTIVE = data.SPAWNav_ACTIVE or false
                if data.currentOffset then currentOffset = Vector3.new(data.currentOffset[1], data.currentOffset[2], data.currentOffset[3]) end
                if data.targets then
                    if data.targets.Mobs then for k, v in pairs(data.targets.Mobs) do if targets.Mobs[k] then targets.Mobs[k] = tostring(v) end end end
                    if data.targets.Bosses then for k, v in pairs(data.targets.Bosses) do if targets.Bosses[k] then targets.Bosses[k] = tostring(v) end end end
                end
            end
        end
    end)
end
