local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

local remote = ReplicatedStorage
    :WaitForChild("ReplicatedPackage")
    :WaitForChild("Remotes")
    :WaitForChild("action")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AutoEquipGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 180, 0, 140)
frame.Position = UDim2.new(0.5, -90, 0.5, -40)
frame.Parent = gui

local button = Instance.new("TextButton")
button.Size = UDim2.new(1, -10, 0, 60)
button.Position = UDim2.new(0, 5, 0, 5)
button.Text = "Auto Equip: OFF"
button.Parent = frame

local spellButton = Instance.new("TextButton")
spellButton.Size = UDim2.new(1, -10, 0, 60)
spellButton.Position = UDim2.new(0, 5, 0, 75)
spellButton.Text = "Auto Spells: OFF"
spellButton.Parent = frame

-- Toggle
local enabled = false
local spellEnabled = false

button.MouseButton1Click:Connect(function()
    enabled = not enabled
    button.Text = enabled and "Auto Equip: ON" or "Auto Equip: OFF"
end)

spellButton.MouseButton1Click:Connect(function()
    spellEnabled = not spellEnabled
    spellButton.Text = spellEnabled and "Auto Spells: ON" or "Auto Spells: OFF"
end)

local function getSpellTools()
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return {} end
    local spells = {}

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool:GetAttribute("Type") == "Spell" then
            table.insert(spells, tool)
        end
    end

    return spells
end

-- Draggable (PC + Mobile)
local dragging = false
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        update(input)
    end
end)

-- BULLETPROOF ENTITY FINDER: Matches via name string instead of distance
local function getEntity()
    local entitiesFolder = workspace:FindFirstChild("Entities")
    if not entitiesFolder then return nil end

    -- Try matching by exact player name inside the Entities folder
    local myEntity = entitiesFolder:FindFirstChild(player.Name)
    if myEntity then return myEntity end

    -- Fallback: If named differently, match via spatial position but with a generous tolerance
    local character = player.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, entity in ipairs(entitiesFolder:GetChildren()) do
        local root = entity:FindFirstChild("HumanoidRootPart")
        -- Expanded distance threshold to 4 studs to absorb server desync lag over hours
        if root and (root.Position - myRoot.Position).Magnitude  0 then
                for _, tool in ipairs(spells) do
                    if tool.Parent == player.Backpack then
                        tool.Parent = character
                        task.wait(0.1)
                    end
                end
            end
        end
    end
end)

-- Auto Equip Loop (Completely decoupled from crashing constraints)
task.spawn(function()
    while true do
        task.wait(1)
        if enabled then
            -- Wrap in pcall so an internal game error never breaks the infinite loop structure
            pcall(function()
                local entity = getEntity()
                if entity then
                    if not entity:FindFirstChild("Weapon") then
                        remote:FireServer("EquipWeapon")
                    end

                    if not entity:FindFirstChild("Grimoire") then
                        remote:FireServer("Book")
                    end
                end
            </pcall>
        end
    end
end)
