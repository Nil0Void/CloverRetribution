local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

local remote = ReplicatedStorage
    :WaitForChild("ReplicatedPackage")
    :WaitForChild("Remotes")
    :WaitForChild("action")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AutoEquipGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 180, 0, 80)
frame.Position = UDim2.new(0.5, -90, 0.5, -40)
frame.Parent = gui

local button = Instance.new("TextButton")
button.Size = UDim2.new(1, -10, 1, -10)
button.Position = UDim2.new(0, 5, 0, 5)
button.Text = "Auto Equip: OFF"
button.Parent = frame

-- Toggle
local enabled = false

button.MouseButton1Click:Connect(function()
    enabled = not enabled
    button.Text = enabled and "Auto Equip: ON" or "Auto Equip: OFF"
end)

-- Draggable (PC + Mobile)
local dragging = false
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        update(input)
    end
end)

-- Find player's entity
local function getEntity()
    local character = player.Character
    if not character then return nil end

    local myRoot = character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, entity in ipairs(workspace.Entities:GetChildren()) do
        local root = entity:FindFirstChild("HumanoidRootPart")

        if root and (root.Position - myRoot.Position).Magnitude < 1 then
            return entity
        end
    end

    return nil
end

-- Auto Equip Loop
task.spawn(function()
    while task.wait(1) do
        if not enabled then
            continue
        end

        local entity = getEntity()

        if entity then
            if not entity:FindFirstChild("Weapon") then
                remote:FireServer("EquipWeapon")
            end

            if not entity:FindFirstChild("Grimoire") then
                remote:FireServer("Book")
            end
        end
    end
end)
